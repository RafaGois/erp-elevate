## 8. PadrГЈo para Data Fetching (Loaders)

```
src/app/(dashboard)/projects/
в”њв”Ђв”Ђ page.tsx                    # Server Component вЂ” usa o loader
в””в”Ђв”Ђ _lib/
    в”њв”Ђв”Ђ projects.loader.ts      # Data fetching com cache()
    в”њв”Ђв”Ђ projects.actions.ts     # Mutations com "use server"
    в””в”Ђв”Ђ projects.schema.ts      # ValidaГ§ГЈo Zod dos inputs
```

```ts
// _lib/projects.loader.ts
import { cache } from 'react'

export const getProjects = cache(async (userId: string) => {
  // Acesso direto ao banco вЂ” apenas em Server Components
  return db.project.findMany({ where: { userId } })
})
```

```ts
// _lib/projects.actions.ts
'use server'
import { revalidatePath } from 'next/cache'
import { createProjectSchema } from './projects.schema'

export async function createProjectAction(formData: FormData) {
  const input = createProjectSchema.parse(Object.fromEntries(formData))
  await projectService.create(input)
  revalidatePath('/projects')
}
```

