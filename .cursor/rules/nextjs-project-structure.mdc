## 9. Padrão para Data Fetching (Loaders)

```
src/app/(dashboard)/projects/
├── page.tsx                    # Server Component — usa o loader
└── _lib/
    ├── projects.loader.ts      # Data fetching com "use cache" ou unstable_cache
    ├── projects.actions.ts     # Mutations com "use server"
    └── projects.schema.ts      # Validação Zod dos inputs
```

```ts
// _lib/projects.loader.ts — com Cache Components habilitado (Next.js 16)
'use cache'
import { cacheTag, cacheLife } from 'next/cache'

export async function getProjects(userId: string) {
  cacheTag(`projects-${userId}`)
  cacheLife('minutes')
  return db.project.findMany({ where: { userId } })
}
```

```ts
// _lib/projects.loader.ts — sem Cache Components (Next.js 15)
import { unstable_cache } from 'next/cache'

export const getProjects = unstable_cache(
  async (userId: string) => db.project.findMany({ where: { userId } }),
  ['projects'],
  { tags: ['projects'], revalidate: 300 }
)
```

```ts
// _lib/projects.actions.ts
'use server'
import { revalidateTag } from 'next/cache'
import { createProjectSchema } from './projects.schema'

export async function createProjectAction(formData: FormData) {
  const input = createProjectSchema.parse(Object.fromEntries(formData))
  await projectService.create(input)
  revalidateTag('projects')
}
```

