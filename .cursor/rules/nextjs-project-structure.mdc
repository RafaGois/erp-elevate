## 14. React 19 — Novidades Relevantes

> Next.js 16 requer React 19.2+. Conheça as APIs que mudam padrões comuns.

```tsx
// hook use() — lê Promises e Context diretamente
import { use } from 'react'

function UserName({ userPromise }: { userPromise: Promise<User> }) {
  const user = use(userPromise) // suspende automaticamente
  return <span>{user.name}</span>
}

// View Transitions — animações nativas entre navegações
import { unstable_ViewTransition as ViewTransition } from 'react'

<ViewTransition>
  <PageContent />
</ViewTransition>

// <Activity /> — mantém estado de componentes "ocultos" (tabs, modais)
import { unstable_Activity as Activity } from 'react'

<Activity mode={isVisible ? 'visible' : 'hidden'}>
  <HeavyComponent />
</Activity>
```

